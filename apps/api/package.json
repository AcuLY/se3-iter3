{
  "name": "@journey/app-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build -w @journey/shared && npm run build && node --watch dist/server.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run --fileParallelism=false",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@journey/shared": "0.1.0",
    "@openai/agents": "^0.1.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "nanoid": "^5.1.5",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
